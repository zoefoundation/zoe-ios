<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>ZOE_API_BASE_URL</key>
	<string>https://zoe.cinnamon-alsephina.ts.net</string>
	<key>NSCameraUsageDescription</key>
	<string>Zoe uses the camera to capture media for provenance signing.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Zoe uses the microphone to record audio during video capture.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Zoe saves signed media to your photo library.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Zoe imports photos and videos to verify their provenance.</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Image</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.image</string>
			</array>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Movie</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.movie</string>
			</array>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
		</dict>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
